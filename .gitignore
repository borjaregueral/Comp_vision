# ── Entorno virtual ──────────────────────────────────────────────
venv/
.venv/
env/

# ── Datos (descargados / generados — pesados, no versionar) ───────
data/
!data/.gitkeep

# ── Salidas de entrenamiento e inferencia ────────────────────────
runs/
results/
reports/
evaluation_results/
data/review_package/
*.pt
*.onnx
*.engine

# ── Estructura operativa (Sprint 0) ──────────────────────────────
# Golden set: siniestros reales (PII) — NUNCA al repo. Solo la estructura.
golden_set/*
!golden_set/.gitkeep
!golden_set/README.md
# Logs de auditoría (JSONL) generados en runtime — no versionar contenido.
logs/*
!logs/.gitkeep
# Pesos de modelos entrenados (las model cards y *_metadata.json SÍ se versionan).
models/*/best.pt
models/*/last.pt
models/*/*.pkl              # calibradores de confianza (artefactos binarios)

# ── Python ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# ── Testing / coverage artefactos ────────────────────────────────
.coverage
.coverage.*
htmlcov/
.pytest_cache/

# ── Reportes de negocio generados (artefactos; no versionar por defecto) ──
eval_business/*.html

# ── Pruebas manuales locales (pueden contener matrículas/fotos — PII) ──
smoke_test/

# ── Credenciales / secretos ──────────────────────────────────────
.env
kaggle.json
*.key

# ── Sistema operativo / editores ─────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp

# Ultralytics auto-downloaded datasets (carparts-seg etc.)
datasets/

# Config local de Claude Code (no debe ir al repo)
.claude/
